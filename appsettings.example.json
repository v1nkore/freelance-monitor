{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "Monitor": {
    "PollIntervalSeconds": 180,
    "Feeds": [
      { "Name": "FL.ru", "Url": "https://www.fl.ru/rss/all.xml", "Enabled": true },
      { "Name": "Freelancehunt", "Url": "https://freelancehunt.com/projects.rss", "Enabled": true },

      { "_comment": "Ниже — источники вакансий/аутстаффа, НЕ разовые задачи. Отключены. Включай, если понадобится найм.",
